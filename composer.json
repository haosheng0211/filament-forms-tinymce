{
    "name": "haosheng0211/filament-forms-tinymce",
    "description": "A Filament v3 form field that integrates TinyMCE 8 rich text editor with dark mode, profiles, and file browser support.",
    "keywords": [
        "laravel",
        "filament",
        "tinymce",
        "rich-text-editor",
        "wysiwyg",
        "form-field",
        "filament-plugin"
    ],
    "homepage": "https://github.com/haosheng0211/filament-forms-tinymce",
    "license": "MIT",
    "authors": [
        {
            "name": "Mr.Jin",
            "email": "haosheng0211@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0||^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0||^8.0.0",
        "pestphp/pest": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^2.0||^3.0||^4.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "MrJin\\FilamentFormsTinymce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MrJin\\FilamentFormsTinymce\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "suggest": {
        "haosheng0211/filament-media-browser": "Required for the built-in file browser feature."
    },
    "extra": {
        "laravel": {
            "providers": [
                "MrJin\\FilamentFormsTinymce\\FilamentFormsTinymceServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
